{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doctor-link.local/schemas/v1/package-export-manifest.schema.json",
  "title": "Doctor link Package Export Manifest",
  "type": "object",
  "required": [
    "schema",
    "package_dir",
    "output_zip",
    "exported_at",
    "validation",
    "included_files",
    "skipped_files",
    "manifest_path",
    "package_readme_path"
  ],
  "properties": {
    "schema": { "const": "doctor-link-package-export-manifest-v1" },
    "package_dir": { "type": "string" },
    "output_zip": { "type": "string" },
    "exported_at": { "type": "string" },
    "validation": { "type": "object" },
    "included_files": { "type": "array", "items": { "type": "object" } },
    "skipped_files": { "type": "array", "items": { "type": "object" } },
    "manifest_path": { "type": "string" },
    "package_readme_path": { "type": "string" }
  },
  "additionalProperties": true
}
